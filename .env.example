# Copy this file to .env and fill in your Spotify app credentials.
# Create your app at: https://developer.spotify.com/dashboard
# Add redirect URI:   http://localhost:8765/callback

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: change the port (also update the redirect URI in Spotify Dashboard)
# SPOTIFY_BRIDGE_PORT=8765